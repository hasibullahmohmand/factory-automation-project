@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <span name="search-icon"></span>
            <input type="search" name="search-bar" class="" placeholder="Search" />
            <NavLink class="nav-item" href="cart">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Cart
            </NavLink>
            <NavLink class="nav-item" href="profile">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Profile
            </NavLink>
            <NavLink class="" >
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Logout
            </NavLink>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
